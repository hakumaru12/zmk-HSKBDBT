// See https://zmk.dev/docs/development/hardware-integration/physical-layouts
// for how to configure this.

#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan>;

        // Edit this to define the positions and sizes of the keys, or remove it
        // if your keyboard will not support ZMK Studio.
        // https://zmk.dev/docs/development/hardware-integration/physical-layouts#optional-keys-property
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0    0       0     0     0>
            , <&key_physical_attrs 100 100  100    0       0     0     0>
            , <&key_physical_attrs 100 100  200    0       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400    0       0     0     0>
            , <&key_physical_attrs 100 100  800    0       0     0     0>
            , <&key_physical_attrs 100 100  900    0       0     0     0>
            , <&key_physical_attrs 100 100 1000    0       0     0     0>
            , <&key_physical_attrs 100 100 1100    0       0     0     0>
            , <&key_physical_attrs 100 100 1200    0       0     0     0>

            , <&key_physical_attrs 100 100    0  120       0     0     0>
            , <&key_physical_attrs 100 100  100  120       0     0     0>
            , <&key_physical_attrs 100 100  200  120       0     0     0>
            , <&key_physical_attrs 100 100  300  120       0     0     0>
            , <&key_physical_attrs 100 100  400  120       0     0     0>
            , <&key_physical_attrs 100 100  800  120       0     0     0>
            , <&key_physical_attrs 100 100  900  120       0     0     0>
            , <&key_physical_attrs 100 100 1000  120       0     0     0>
            , <&key_physical_attrs 100 100 1100  120       0     0     0>
            , <&key_physical_attrs 100 100 1200  120       0     0     0>

            , <&key_physical_attrs 100 100    0  240       0     0     0>
            , <&key_physical_attrs 100 100  100  240       0     0     0>
            , <&key_physical_attrs 100 100  200  240       0     0     0>
            , <&key_physical_attrs 100 100  300  240       0     0     0>
            , <&key_physical_attrs 100 100  400  240       0     0     0>
            , <&key_physical_attrs 100 100  800  240       0     0     0>
            , <&key_physical_attrs 100 100  900  240       0     0     0>
            , <&key_physical_attrs 100 100 1000  240       0     0     0>
            , <&key_physical_attrs 100 100 1100  240       0     0     0>
            , <&key_physical_attrs 100 100 1200  240       0     0     0>

            , <&key_physical_attrs 100 100    0  360       0     0     0>
            , <&key_physical_attrs 100 100  100  360       0     0     0>
            , <&key_physical_attrs 100 100  200  360       0     0     0>
            , <&key_physical_attrs 100 100  300  360       0     0     0>
            , <&key_physical_attrs 100 100  400  360       0     0     0>
            , <&key_physical_attrs 100 100  500  360       0     0     0>
            , <&key_physical_attrs 100 100  700  360       0     0     0>
            , <&key_physical_attrs 100 100  800  360       0     0     0>
            , <&key_physical_attrs 100 100  900  360       0     0     0>
            , <&key_physical_attrs 100 100 1000  360       0     0     0>
            , <&key_physical_attrs 100 100 1100  360       0     0     0>
            , <&key_physical_attrs 100 100 1200  360       0     0     0>
            ;
    };
};
